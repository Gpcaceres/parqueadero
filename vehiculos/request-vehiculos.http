### Variables
@baseUrl = http://localhost:3000
@contentType = application/json

# ─── CREATE ────────────────────────────────────────────────────────────────────

### 1. Crear Auto - HIBRIDO
POST {{baseUrl}}/vehiculos
Content-Type: {{contentType}}

{
  "tipo": "Auto",
  "datos": {
    "placa": "ABC-4791",
    "marca": "Toyota",
    "modelo": "Corolla",
    "color": "Blanco",
    "anio": 2023,
    "clasificacion": "HIBRIDO",
    "numeroPuertas": 4,
    "capacidadMaletero": 450,
    "capacidadCarga": 500
  }
}

### 2. Crear Motocicleta - GASOLINA
POST {{baseUrl}}/vehiculos
Content-Type: {{contentType}}

{
  "tipo": "Moto",
  "datos": {
    "placa": "MOT-1234",
    "marca": "Honda",
    "modelo": "CBR600",
    "color": "Rojo",
    "anio": 2022,
    "clasificacion": "GASOLINA",
    "tipo": "Deportiva"
  }
}

### 3. Crear Camioneta - DIESEL
POST {{baseUrl}}/vehiculos
Content-Type: {{contentType}}

{
  "tipo": "Camioneta",
  "datos": {
    "placa": "CAM-9900",
    "marca": "Ford",
    "modelo": "Ranger",
    "color": "Gris",
    "anio": 2021,
    "clasificacion": "DIESEL",
    "capacidadCarga": 1000,
    "cabina": "Doble"
  }
}

# ─── READ ──────────────────────────────────────────────────────────────────────

### 4. Obtener todos los vehiculos
GET {{baseUrl}}/vehiculos

### 5. Obtener vehiculo por ID
GET {{baseUrl}}/vehiculos/1

# ─── UPDATE ────────────────────────────────────────────────────────────────────

### 6. Actualizar Auto (cambiar color y clasificacion)
PATCH {{baseUrl}}/vehiculos/1
Content-Type: {{contentType}}

{
  "tipo": "Auto",
  "datos": {
    "color": "Negro",
    "clasificacion": "GASOLINA"
  }
}

### 7. Actualizar Motocicleta (cambiar modelo)
PATCH {{baseUrl}}/vehiculos/2
Content-Type: {{contentType}}

{
  "tipo": "Moto",
  "datos": {
    "modelo": "CBR1000",
    "color": "Azul"
  }
}

### 8. Actualizar Camioneta (cambiar cabina)
PATCH {{baseUrl}}/vehiculos/3
Content-Type: {{contentType}}

{
  "tipo": "Camioneta",
  "datos": {
    "cabina": "Simple",
    "capacidadCarga": 800
  }
}

# ─── DELETE ────────────────────────────────────────────────────────────────────

### 9. Eliminar vehiculo por ID
DELETE {{baseUrl}}/vehiculos/12

### 4. Obtener todos los vehiculos
GET {{baseUrl}}/vehiculos
