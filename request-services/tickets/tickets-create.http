@baseUrlPersonas = http://localhost:3001
@baseUrlVehiculos = http://localhost:3000
@baseUrlZonas = http://localhost:8080/api/v1
@baseUrlTickets = http://localhost:3003
@contentType = application/json

# Flujo completo de creación de ticket desde quien lo genera: el recaudador
# (o admin) que atiende la caseta cuando ingresa un vehículo. POST /tickets
# es staff-only (admin/recaudador/root, ver tickets.controller.ts) -- un
# cliente no puede crear su propio ticket (ver asignar-tickets/clientes.http).
# Cubre: login, consultar espacios para elegir dónde asignar, crear el
# ticket, verlo entre los asignados, y cerrarlo (salida + recaudación).

### 0. Login como recaudador (quien atiende la caseta y genera el ticket)
# @name login
POST {{baseUrlPersonas}}/auth/login
Content-Type: {{contentType}}

{
  "username": "{{recaudadorUserName}}",
  "password": "{{recaudadorPassword}}"
}

### 1. Consultar los espacios de la zona para elegir uno DISPONIBLE
GET {{baseUrlZonas}}/espacios/zona/{{zonaId}}
Accept: application/json

### 2. Verificar que el vehículo que va a ingresar existe
GET {{baseUrlVehiculos}}/vehiculos/{{vehiculoId}}
Accept: application/json

### 3. Crear el ticket (asigna al vehículo el espacio elegido en el paso 1)
# id_empleado se autocompleta con el usuario del token (rol admin/recaudador/root).
# fecha_hora_ingreso ya NO se manda: el servidor la captura sola con su hora
# real al procesar la creación (ver TicketsService.createTicket), igual que
# fecha_hora_salida en el paso 5 -- así las horas/fracción cobradas siempre
# corresponden al tiempo real transcurrido.
# @name crearTicket
POST {{baseUrlTickets}}/tickets
Content-Type: {{contentType}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "id_usuario": "{{userId}}",
  "id_espacio": "{{espacioId}}",
  "id_vehiculo": "{{vehiculoPlaca}}",
  "tipo_vehiculo": "Auto",
  "tipo_tarifa": "POR_HORA"
}

### 4. Ver los tickets asignados al usuario (confirmar que quedó creado)
GET {{baseUrlTickets}}/tickets/usuario/{{userId}}
Accept: application/json

### 5. Registrar la salida del vehículo (cierra el ticket)
# fecha_hora_salida ya NO se manda en el body: el servidor la captura sola
# con la hora real del momento en que se procesa la salida (ver
# TicketsService.registrarSalida), precisamente para que el espacio se
# libere con la fecha/hora exacta en que ocurrió, no una que el cliente
# pudiera inventar.
PATCH {{baseUrlTickets}}/tickets/{{crearTicket.response.body.$.id_ticket}}/salida
Authorization: Bearer {{login.response.body.$.access_token}}

### 6. Ver el ticket ya cerrado, con su recaudación
# valor_recaudado ya NO se registra manualmente: el paso 5 (/salida) lo
# calcula solo a partir de tipo_tarifa y el tiempo real transcurrido (ver
# TicketsService.registrarSalida y tarifas.ts). No existe un PATCH para
# fijarlo a mano.
GET {{baseUrlTickets}}/tickets/{{crearTicket.response.body.$.id_ticket}}
Accept: application/json
