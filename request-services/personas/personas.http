@baseUrl = http://localhost:3001
@contentType = application/json

# GET /personas exige estar autenticado (cualquier rol); POST/PATCH/DELETE
# exigen admin o root (ver personas.controller.ts).

### 0. Login como admin
# @name login
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "username": "{{adminUserName}}",
  "password": "{{adminPassword}}"
}

### 1. Listar todas las personas
GET {{baseUrl}}/personas
Authorization: Bearer {{login.response.body.$.access_token}}
Accept: application/json

### 2. Crear persona
POST {{baseUrl}}/personas
Content-Type: {{contentType}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "dni": "1718433624",
  "email": "recaus@test.com",
  "first_name": "Tnt",
  "middle_name": "Buestan",
  "last_name": "Buestans",

  "nationality": "Ecuador",
  "phone": "999999998",
  "address": "Calle 123 # 45-67"
}

### 3. Obtener persona por ID (usa la variable compartida personaId)
GET {{baseUrl}}/personas/{{personaId}}
Authorization: Bearer {{login.response.body.$.access_token}}
Accept: application/json

### 4. Actualizar persona
PATCH {{baseUrl}}/personas/{{personaId}}
Content-Type: {{contentType}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "first_name": "Juan",
  "last_name": "Perez",
  "middle_name": "Carlos",
  "nationality": "Colombia",
  "phone": "3109876543",
  "address": "Avenida 456 # 78-90"
}

### 5. Eliminar persona
# Borra en cascada el usuario asociado (y sus roles) gracias al ON DELETE CASCADE
DELETE {{baseUrl}}/personas/{{personaId}}
Authorization: Bearer {{login.response.body.$.access_token}}
Accept: application/json
