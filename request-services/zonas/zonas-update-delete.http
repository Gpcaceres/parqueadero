@baseUrlPersonas = http://localhost:3001
@baseUrl = http://localhost:8080/api/v1
@contentType = application/json

# PUT/PATCH /zonas exigen un token con rol admin, root o recaudador.

### 0. Login como admin
# @name login
POST {{baseUrlPersonas}}/auth/login
Content-Type: {{contentType}}

{
  "username": "{{adminUserName}}",
  "password": "{{adminPassword}}"
}

### 1. Actualizar zona (usa la variable compartida zonaId)
# tipoZona debe ser uno de: VIP, REGULAR, INTERNA, EXTERNA, PREFERENCIAL
PUT {{baseUrl}}/zonas/{{zonaId}}
Content-Type: {{contentType}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "nombre": "Zona Prueba Actualizada",
  "descripcion": "Zona actualizada desde prueba HTTP",
  "tipoZona": "REGULAR",
  "capacidad": 2
}

### 2. Activar / desactivar zona
PATCH {{baseUrl}}/zonas/{{zonaId}}/activar-desactivar
Authorization: Bearer {{login.response.body.$.access_token}}
Accept: application/json
