@baseUrlPersonas = http://localhost:3001
@baseUrl = http://localhost:8080/api/v1
@contentType = application/json

# PUT/PATCH /espacios exigen un token con rol admin, root o recaudador.

### 0. Login como admin
# @name login
POST {{baseUrlPersonas}}/auth/login
Content-Type: {{contentType}}

{
  "username": "{{adminUserName}}",
  "password": "{{adminPassword}}"
}

### 1. Actualizar espacio (usa la variable compartida espacioId/zonaId)
# tipo debe ser uno de: MOTO, CARRO, AUTOBUS
PUT {{baseUrl}}/espacios/{{espacioId}}
Content-Type: {{contentType}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "idZona": "{{zonaId}}",
  "descripcion": "Espacio actualizado para prueba",
  "tipo": "MOTO",
  "estado": "DISPONIBLE"
}

### 2. Activar / desactivar espacio
PATCH {{baseUrl}}/espacios/{{espacioId}}/activar-desactivar
Authorization: Bearer {{login.response.body.$.access_token}}
Accept: application/json

### 3. Reservar espacio (estado debe ser uno de: DISPONIBLE, OCUPADO,
# RESERVADO, MANTENIMIENTO, INACTIVO). El dashboard (front-end/dashboard-
# cliente) pinta este estado en un color propio (coral suave), distinto del
# verde de DISPONIBLE y el rojo de OCUPADO -- se refleja solo, ya que el
# dashboard consulta GET /api/v1/espacios sin filtrar por estado y colorea
# la tarjeta según lo que reciba.
PUT {{baseUrl}}/espacios/{{espacioId}}
Content-Type: {{contentType}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "idZona": "{{zonaId}}",
  "descripcion": "Espacio reservado para prueba",
  "tipo": "MOTO",
  "estado": "RESERVADO"
}

### 4. Poner espacio en mantenimiento (color ámbar en el dashboard, distinto
# del coral de RESERVADO)
PUT {{baseUrl}}/espacios/{{espacioId}}
Content-Type: {{contentType}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "idZona": "{{zonaId}}",
  "descripcion": "Espacio en mantenimiento para prueba",
  "tipo": "MOTO",
  "estado": "MANTENIMIENTO"
}

