@baseUrlPersonas = http://localhost:3001
@baseUrl = http://localhost:8080/api/v1
@contentType = application/json

# PUT/PATCH /espacios exigen un token con rol admin, root o recaudador.

### 0. Login como admin
# @name login
POST {{baseUrlPersonas}}/auth/login
Content-Type: {{contentType}}

{
  "username": "{{adminUserName}}",
  "password": "{{adminPassword}}"
}

### 1. Actualizar espacio (usa la variable compartida espacioId/zonaId)
# tipo debe ser uno de: MOTO, CARRO, AUTOBUS
PUT {{baseUrl}}/espacios/{{espacioId}}
Content-Type: {{contentType}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "idZona": "{{zonaId}}",
  "descripcion": "Espacio actualizado para prueba",
  "tipo": "MOTO",
  "estado": "DISPONIBLE"
}

### 2. Activar / desactivar espacio
PATCH {{baseUrl}}/espacios/{{espacioId}}/activar-desactivar
Authorization: Bearer {{login.response.body.$.access_token}}
Accept: application/json


