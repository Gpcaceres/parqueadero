@baseUrlPersonas = http://localhost:3001
@baseUrl = http://localhost:3000
@contentType = application/json

# PATCH/DELETE /vehiculos exigen un token con rol admin, root o recaudador.

### 0. Login como admin
# @name login
POST {{baseUrlPersonas}}/auth/login
Content-Type: {{contentType}}

{
  "username": "{{adminUserName}}",
  "password": "{{adminPassword}}"
}

### 1. Actualizar vehículo (usa la variable compartida vehiculoId)
PATCH {{baseUrl}}/vehiculos/{{vehiculoId}}
Content-Type: {{contentType}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "tipo": "Auto",
  "datos": {
    "color": "Negro",
    "clasificacion": "GASOLINA"
  }
}

### 2. Eliminar vehículo
DELETE {{baseUrl}}/vehiculos/{{vehiculoId}}
Authorization: Bearer {{login.response.body.$.access_token}}
Accept: application/json

### 3. Verificar eliminación
GET {{baseUrl}}/vehiculos
Accept: application/json
