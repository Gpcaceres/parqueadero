# ===== Servidor =====
NODE_ENV=development
PORT=3002

# ===== Base de Datos =====
DB_HOST=localhost
DB_PORT=5434
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=asignacion_db
DB_LOGGING=false

# ===== Microservicios Integrados =====
# Microservicio de Vehículos (NestJS)
VEHICLE_SERVICE_URL=http://host.docker.internal:3000
# O en Docker usar:
# VEHICLE_SERVICE_URL=http://vehiculos:3000

# Microservicio de Personas/Usuarios
USER_SERVICE_URL=http://host.docker.internal:3001
# O en Docker usar:
# USER_SERVICE_URL=http://personas:3001

# Microservicio de Zonas (Spring Boot)
ZONE_SERVICE_URL=http://host.docker.internal:8080
# O en Docker usar:
# ZONE_SERVICE_URL=http://zonas:8080

# ===== Logging =====
LOG_LEVEL=debug

# ===== JWT (Opcional) =====
JWT_SECRET=your-secret-key
JWT_EXPIRATION=24h
