# Kong Gateway .gitignore

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# Runtime data
# ============================================
pids/
*.pid
*.seed
*.pid.lock

# ============================================
# OS
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================
# IDEs and editors
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ============================================
# dotenv environment variable files
# ============================================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ============================================
# Docker
# ============================================
docker-compose.override.yml
.docker/
docker-volume-data/

# ============================================
# Kong specific
# ============================================
kong-data/
kong_db_data/
pg_data/
kong-migrations.sql
kong-plugins/

# ============================================
# Scripts output
# ============================================
configure-kong.log
register-service.log
health-check.log

# ============================================
# Temporary files
# ============================================
.tmp/
.temp/
tmp/
temp/

# ============================================
# Database
# ============================================
*.db
*.sqlite
*.sqlite3
dump.sql
postgres_data/

# ============================================
# Backup files
# ============================================
*.bak
*.backup
*.swp

# ============================================
# Sensitive information
# ============================================
*.pem
*.key
*.crt
*.cert
secrets/
credentials.json

# ============================================
# Node modules (if using any scripts)
# ============================================
node_modules/
package-lock.json
npm-debug.log

# ============================================
# IDE specific
# ============================================
.IntelliJIdea*
*.iml
*.iws
*.ipr

# ============================================
# Cache
# ============================================
.cache/
.eslintcache

# ============================================
# Artifacts
# ============================================
/dist
/build
/out
