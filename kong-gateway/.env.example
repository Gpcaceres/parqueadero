# ===== Kong Database =====
KONG_PG_HOST=kong-db
KONG_PG_PORT=5432
KONG_PG_DATABASE=kong
KONG_PG_USER=kong
KONG_PG_PASSWORD=kong123

# ===== Kong Configuration =====
KONG_DATABASE=postgres
KONG_ADMIN_LISTEN=0.0.0.0:8001
KONG_ADMIN_GUI_URL=http://localhost:8002
KONG_ADMIN_GUI_LISTEN=0.0.0.0:8002

# ===== Kong Proxy =====
KONG_PROXY_ACCESS_LOG=/dev/stdout
KONG_ADMIN_ACCESS_LOG=/dev/stdout
KONG_PROXY_ERROR_LOG=/dev/stderr
KONG_ADMIN_ERROR_LOG=/dev/stderr

# ===== Puertos =====
KONG_PROXY_PORT=8000
KONG_PROXY_SSL_PORT=8443
KONG_ADMIN_PORT=8001
KONG_ADMIN_SSL_PORT=8444
KONG_MANAGER_PORT=8002
POSTGRES_PORT=5433

# ===== Microservicios URLs =====
# Estos son los hosts donde corren los microservicios
# Usar host.docker.internal en Docker Desktop (Mac/Windows)
# Usar localhost o IP de la máquina en Linux
ZONAS_URL=http://host.docker.internal:8080
VEHICULOS_URL=http://host.docker.internal:3000
PERSONAS_URL=http://host.docker.internal:3001

# ===== URLs de Acceso =====
KONG_ADMIN_API_URL=http://localhost:8001
KONG_PROXY_URL=http://localhost:8000
KONG_MANAGER_URL=http://localhost:8002

# ===== Configuración de Rate Limiting =====
RATE_LIMIT_MINUTE=100
RATE_LIMIT_POLICY=local

# ===== CORS =====
CORS_ORIGINS=*
CORS_CREDENTIALS=true
CORS_MAX_AGE=3600
