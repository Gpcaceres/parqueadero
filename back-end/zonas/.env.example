# ===== Base de Datos para la Aplicación Zonas =====
DB_HOST=postgres
DB_PORT=5432
DB_NAME=zonas_db
DB_USER=postgres
DB_PASSWORD=postgres

# ===== Base de Datos para Kong =====
KONG_DB_HOST=kong-db
KONG_DB_PORT=5432
KONG_DB_NAME=kong
KONG_DB_USER=kong
KONG_DB_PASSWORD=kong

# ===== Configuración de Kong =====
KONG_ADMIN_API_URL=http://localhost:8001
KONG_PROXY_URL=http://localhost:8000
KONG_MANAGER_URL=http://localhost:8002

# ===== Configuración de la Aplicación Spring Boot =====
SPRING_PROFILE=docker
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/zonas_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ===== Configuración de Swagger/OpenAPI =====
SPRINGDOC_SWAGGER_UI_ENABLED=true
SPRINGDOC_API_DOCS_PATH=/v3/api-docs
